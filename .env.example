# Supabase Project URL — the BASE url only, NOT the /rest/v1 endpoint.
# Find it at: Supabase Dashboard → Settings → API → "Project URL"
#   Correct: https://your-ref.supabase.co
#   Wrong:   https://your-ref.supabase.co/rest/v1
VITE_SUPABASE_URL=

# Supabase anon / public key (safe to expose in the browser — RLS protects data).
VITE_SUPABASE_ANON_KEY=

# OPTIONAL — only for local tooling (e.g. `npm run upload-assets`).
# The service_role key BYPASSES RLS. Never prefix it with VITE_, never commit it.
SUPABASE_SERVICE_ROLE_KEY=
